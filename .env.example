# Copy this file to .env and adjust values for your environment.

# Images (prefer pinning to specific versions/digests for reproducibility)
N8N_IMAGE=n8nio/n8n@sha256:a9beb0dcaa547f0742a322f497af72127338d6ab8f3697b3be44f8ab737726f2
POSTGRES_IMAGE=ankane/pgvector@sha256:956744bd14e9cbdf639c61c2a2a7c7c2c48a9c8cdd42f7de4ac034f4e96b90f8
REDIS_IMAGE=redis@sha256:02f2cc4882f8bf87c79a220ac958f58c700bdec0dfb9b9ea61b62fb0e8f1bfcf
NGROK_IMAGE=ngrok/ngrok@sha256:d20e9631f5d5744353558b0d4bd5c5274bb2cc726c546a1a4873b59548024894

# Timezone
TZ=America/Cuiaba

# n8n
N8N_EDITOR_PORT=5678
WEBHOOK_URL=https://your-subdomain.ngrok-free.dev/

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=postgres

# ngrok (used only when running with profile "tunnel")
NGROK_DOMAIN=your-subdomain.ngrok-free.dev
NGROK_AUTHTOKEN=replace_with_your_token
NGROK_DASHBOARD_PORT=4040
